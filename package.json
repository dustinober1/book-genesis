  "description": "PI-native autonomous book generation package built on @mariozechner/pi-coding-agent.",
  "author": "Derived from Book Genesis by Philip Stark",
  "contributors": [
    "Philip Stark (original Book Genesis concept, prompts, pipeline design, and open-source development)"
  ],
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
